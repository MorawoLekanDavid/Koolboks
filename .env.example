# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Database Configuration (PostgreSQL)
# In Docker, use postgres:5432 as hostname
# For local development: localhost:5432
DB_PASSWORD=your_secure_db_password_here
DATABASE_URL=postgresql://koolbuy:your_secure_db_password_here@postgres:5432/koolbuy

# Redis Configuration
# In Docker, this should be: redis://redis:6379
# For local development: redis://localhost:6379
REDIS_URL=redis://redis:6379

# Chat Configuration
CHAT_TTL=3600
MAX_HISTORY_MESSAGES=20
REDIS_LEAD_TTL=86400

# WhatsApp contact shown to customers after phone capture
WHATSAPP_CONTACT=+2348106912022

# WhatsApp Integration (future)
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
